# kb-mcp frontmatter スキーマのサンプル。
#
# このファイルを `<kb-path>/kb-mcp-schema.toml` にコピーして使う。
# スキーマファイルが存在しない場合、`kb-mcp validate` は "no schema found"
# として exit 0 で終了する (検証を有効化していない状態と同じ挙動)。
#
# フィールド単位で以下の制約が書ける:
#   required      : true なら欠落 / 空文字列 / 空配列は違反
#   type          : "string" / "integer" / "date" / "array"
#   pattern       : 正規表現 (string 型にのみ、Rust `regex` 互換)
#                   single-quoted literal `'...'` が TOML で推奨
#   enum          : 許容値リスト (string または array 要素を完全一致判定)
#   min_length    : string なら文字数、array なら要素数の下限
#   max_length    : string なら文字数、array なら要素数の上限
#   allow_empty   : required=true でも空を許容する opt-in フラグ
#
# 検証対象は現状 `.md` のみ。`.txt` は frontmatter 概念なしで skip。
# 未サポートキー (title/date/topic/depth/tags 以外) は reject される。

[fields.title]
required = true
type = "string"
min_length = 1

[fields.date]
required = true
type = "string"
pattern = '^\d{4}-\d{2}-\d{2}$'   # ISO-8601 date

[fields.topic]
required = true
type = "string"
enum = ["mcp", "rag", "ai", "tooling", "ops"]

# optional: depth が書かれている場合のみ enum を適用
[fields.depth]
required = false
type = "string"
enum = ["1", "2", "3"]

[fields.tags]
required = true
type = "array"
min_length = 1
max_length = 10
