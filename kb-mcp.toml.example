# kb-mcp 設定ファイルのサンプル。
#
# このファイルをバイナリ (kb-mcp / kb-mcp.exe) と**同じディレクトリ**に
# `kb-mcp.toml` という名前でコピーして使う。
# CLI 引数で明示指定した項目が常に優先されるため、ここでは運用時の既定値を
# 書いておく想定。すべてのキーは optional (省略すればビルトイン既定値)。

# 対象 knowledge-base ディレクトリの絶対パス。
# 指定すると `--kb-path` を省略できる。
#kb_path = "/path/to/knowledge-base"

# 既定の埋め込みモデル。
#   bge-small-en-v1.5 … 英語特化、384 次元、~130 MB (既定)
#   bge-m3            … 多言語 (日本語 OK)、1024 次元、~2.3 GB
#model = "bge-m3"

# 既定の cross-encoder reranker。
#   none       … 無効 (既定)
#   bge-v2-m3  … BAAI/bge-reranker-v2-m3 (多言語、~2.3 GB、日本語推奨)
#   jina-v2-ml … jinaai/jina-reranker-v2-base-multilingual (~1.2 GB、軽量多言語)
#   bge-base   … BAAI/bge-reranker-base (英/中、~280 MB)
#reranker = "bge-v2-m3"

# reranker が有効なとき、各 `search` 呼び出しで自動的に rerank を適用するか。
# MCP ツール `search` の `rerank` パラメータで個別上書き可能。
#rerank_by_default = true

# fastembed のモデルキャッシュディレクトリ。
# 既に環境変数 `FASTEMBED_CACHE_DIR` が設定されていれば env が優先される。
# `hf download` で事前 DL した HF Hub キャッシュ (~/.cache/huggingface/hub)
# を指しておくと、fastembed の TLS で DL 失敗する環境でも流用できる。
#fastembed_cache_dir = "/home/yabushita/.cache/huggingface/hub"

# Markdown チャンク化時に除外する見出しの substring リスト。
# 省略すると除外なし (全見出しをチャンク化)。リストを指定すると、
# そのいずれかを substring として含む見出しのセクションが落とされる。
# 例: 「参考リンク」と「次の深堀り候補」を落としたい場合:
#exclude_headings = ["参考リンク", "次の深堀り候補"]

# インデックス走査時にスキップするディレクトリ basename のリスト。
# basename 完全一致 (substring や glob ではない)。省略時の既定は
# [".obsidian", ".git", "node_modules", "target", ".vscode", ".idea"]。
# 指定すると既定を**置き換える** (merge ではない)。`[]` を明示すると
# 何も除外せず全ディレクトリを走査する。
# 例: 既定 + Next.js ビルド出力を足したい場合:
#exclude_dirs = [".obsidian", ".git", "node_modules", "target", ".vscode", ".idea", "dist", ".next"]
# 例: 除外を全部外して全ディレクトリを走査したい場合:
#exclude_dirs = []

# 検索時のチャンク品質フィルタ。
# enabled を false にすると MCP search / CLI search / get_connection_graph
# すべてでフィルタが無効になり、従来の全件返却動作に戻る。
# threshold は 0.0 から 1.0 の範囲で、未満のスコアのチャンクを除外する。
# 既定はフィルタ有効 + threshold 0.3。
[quality_filter]
enabled = true
threshold = 0.3

# `get_best_practice` MCP ツール (opt-in)。`[best_practice]` セクションを
# 省略、あるいは `path_templates = []` を明示すると、ツールは "not configured"
# エラーを返し機能しない。利用するにはテンプレートを 1 つ以上列挙する。
# 先頭から順に `{target}` を置換して kb_path 相対で探し、最初に見つかった
# ファイルを返す。`target` 引数は canonicalize + kb_path 配下のチェックあり。
# opt-out したい場合はこのセクションを丸ごと削除する。
[best_practice]
path_templates = ["best-practices/{target}/PERFECT.md", "docs/{target}.md"]

# Indexing 対象の拡張子レジストリ。
# 3 状態セマンティクス:
#   - セクション自体なし        … ["md"] のみ (デフォルト)
#   - 明示的な空配列           … エラー (silent failure 防止)
#   - 独自リスト                … そのリストに含まれる拡張子だけを対象に
# 現状のバイナリで対応する id: "md" / "txt"
# ("pdf" / "docx" / "rst" / "adoc" 等は将来追加予定、現在指定するとエラー)
# 下記は .txt も index したい場合の例 ("md" のみ既定なら [parsers] ごと削除)。
[parsers]
enabled = ["md", "txt"]

# ファイルウォッチャー。`kb-mcp serve` 中のみ有効。
# 有効時は kb_path 配下の変更 / 追加 / 削除 / rename を検知して
# 該当ファイルだけを増分再インデックスする (PostToolUse hook が拾えない
# 手動編集・git pull・外部スクリプト経由の更新もカバー)。
# CLI `--no-watch` / `--debounce-ms <ms>` で per-run override 可能。
# セクション自体を省略した場合も enabled=true / 500ms が既定。
[watch]
enabled = true
debounce_ms = 500

# トランスポート設定。`kb-mcp serve` が listen する方式を選ぶ。
# kind は "stdio" (1 クライアント限定、既定) か "http"
# (Streamable HTTP、複数クライアント同時接続可)。省略 (セクション自体なし)
# なら stdio。[transport.http] だけ書けば kind 省略でも http 扱い (糖衣)。
# HTTP 時の mount path は /mcp 固定、/healthz が 200 を返す。CLI
# `--transport http --port 3100` / `--bind 0.0.0.0:3100` で per-run override。
# 既定 bind は 127.0.0.1:3100 (loopback)。0.0.0.0 は opt-in、本番公開する場合は
# 認証層 (nginx + basic auth 等の前段リバースプロキシ) を必ず挟むこと。
[transport]
kind = "http"

[transport.http]
bind = "127.0.0.1:3100"

# 受理する Host ヘッダの allow-list (DNS rebinding 防御、v0.5.0+)。
# 省略時 (このキー自体を書かない) は rmcp の default
# `["localhost", "127.0.0.1", "::1"]` (loopback only) が使われる。
# LAN / イントラ公開時は **必ず明示する** (loopback only のまま 0.0.0.0
# で bind すると外部 Host の inbound は Host header validation で 403。
# これは通常 operator のミスなので、起動時に warn が出る)。
# 空配列を渡すと **全 Host 許可** になる (rmcp の disable_allowed_hosts
# 相当、public 公開時は推奨されない)。
#allowed_hosts = ["kb.example.lan", "192.168.1.10", "192.168.1.10:3100"]

# F-64 (v0.7.5+): /healthz endpoint も allowed_hosts allow-list 配下に置くか。
# 既定は true (= public、現行挙動、Host check なし)。false にすると
# /healthz も Host header 検証され、non-allowlisted host から 403。
# kb-mcp の存在 fingerprinting を防ぎたい時に opt-in。
#healthz_public = false

# --- eval (retrieval quality evaluation, optional power-user feature) ---
# 詳細は docs/eval.md / docs/eval.ja.md を参照。省略時は全デフォルトで動作する。
# セクション自体を丸ごと削除してよい。残す場合、各フィールドはすべて optional
# (以下の値はビルトイン既定値と同じ)。
[eval]
#golden = ".kb-mcp-eval.yml"            # Golden YAML パス (default: <kb_path>/.kb-mcp-eval.yml)
#history_size = 10                      # 履歴保持件数 (default: 10)
#k_values = [1, 5, 10]                  # 報告する k (default: [1, 5, 10])
#regression_threshold = 0.05            # diff 色付けの閾値 (default: 0.05)

# --- search (search ツール追加設定、v0.3.0+) ---
# rank-based low_confidence 判定の閾値。top1.score / mean(top-N.score) <
# ratio で flag が立つ。0.0 で判定無効。CLI `--min-confidence-ratio` /
# MCP param `min_confidence_ratio` で per-query 上書き可。省略時は 1.5。
# セクション自体を丸ごと削除してよい (既定値で動作する)。
[search]
#min_confidence_ratio = 1.5             # default: 1.5

# [search.mmr] (optional, v0.7.0+).
# Maximal Marginal Relevance: post-rerank diversity correction.
# Defaults below show the built-in values (kept commented). Leaving
# the section as-is opts into the default behavior with MMR off.
# Uncomment specific keys to override. See docs/retrieval-pipeline.md.
[search.mmr]
#enabled = false
#lambda = 0.7              # 1.0 means no diversity (MMR off equivalent); < 0.5 leans exploration
#same_doc_penalty = 0.0    # > 0 deduplicates same-document chunks; 0 means pure MMR

# [search.parent_retriever] (optional, v0.7.0+).
# Display-time content expansion for hit chunks. Defaults below are the
# built-in values (kept commented). Leaving the section as-is opts into
# the default behavior with parent retriever off. When enabled, short
# hits are expanded to adjacent siblings or the whole document so the
# LLM gets enough context. Score / rank / match_spans of the original
# hit are preserved (only `content` and the new `expanded_from` field
# change). See docs/retrieval-pipeline.md.
[search.parent_retriever]
#enabled = false
#whole_doc_threshold_tokens = 100     # token_count below this -> whole document fallback
#max_expanded_tokens = 2000           # cap for adjacent merge / whole-doc (BGE-M3 supports up to 8192)
