/target/

# fastembed-rs が cache_dir 未解決時に使うローカルフォールバック
.fastembed_cache/

# Claude Code (local settings, reproducible skills)
CLAUDE.local.md
*.local.md
.claude/settings.local.json
.claude/scheduled_tasks.lock
.agents/
.remember/
.playwright-mcp/
.mcp.json

# Runtime config placed next to the binary (user-local). Template is kb-mcp.toml.example.
kb-mcp.toml

# Generated SQLite DB files (one per kb_path.parent()). Bench fixtures under
# tests/fixtures/kb-bench/ generate `.kb-mcp.db` next to them when indexed.
**/.kb-mcp.db

# Deployment recipe templates under kb-mcp/examples/deployments/ are meant to be
# committed (they are example artifacts, not user-local runtime files).
# (feature-44 PR-1 / codex P3 round 3 on PR #61): updated path after workspace
# split moved examples/ to kb-mcp/examples/.
!kb-mcp/examples/deployments/**/.mcp.json
!kb-mcp/examples/deployments/**/kb-mcp.toml

# /codex-review skill working directory (= per-round baseline JSON snapshots)
.codex-review-tmp/
